# =============================================================================
# Azure DevOps / CI Environment Configuration for PSP Payment System
# =============================================================================
#
# Usage with direnv:
#   1. Copy this file: cp .envrc.example .envrc
#   2. Fill in your actual values
#   3. Run: direnv allow
#
# Usage without direnv:
#   source configs/.envrc
#
# IMPORTANT: Never commit .envrc to version control.
# =============================================================================

# -- Azure DevOps Configuration ------------------------------------------------
export AZURE_DEVOPS_EXT_PAT="<your-azure-devops-pat>"
export AZURE_DEVOPS_DEFAULTS_ORGANIZATION="https://dev.azure.com/<your-org>"
export AZURE_DEVOPS_DEFAULTS_PROJECT="psp-payment-system"

# -- CI/CD Pipeline Variables --------------------------------------------------
# These are consumed by Azure Pipelines and local preflight-validate.sh
export CI_PROJECT_NAME="dbx-lakeflow-psp-payment-system"
export CI_ENVIRONMENT="dev"

# -- Databricks Auth (CI/CD service principal) ---------------------------------
# Used by CI runners; local dev should use `databricks auth login` instead
export DATABRICKS_CLIENT_ID="<service-principal-client-id>"
export DATABRICKS_CLIENT_SECRET="<service-principal-client-secret>"

# -- Feature Flags (for conditional pipeline gates) ----------------------------
export ENABLE_E2E_TESTS="false"
export ENABLE_SECURITY_SCAN="true"
export ENABLE_SQL_VALIDATION="true"
export ENABLE_DABS_VALIDATE="true"
