#!/usr/bin/env bash
# =============================================================================
# Databricks CLI Environment Configuration for PSP Payment System
# =============================================================================
#
# Usage:
#   1. Copy this file: cp databricks-env.sh.example databricks-env.sh
#   2. Fill in your actual values
#   3. Source it: source configs/databricks-env.sh
#
# Prerequisites:
#   - Databricks CLI >= 0.283.0 (DABs support)
#   - Authenticated via: databricks auth login --host <HOST>
#
# IMPORTANT: Never commit databricks-env.sh to version control.
# =============================================================================

# -- Workspace Hosts -----------------------------------------------------------
export DATABRICKS_HOST_DEV="https://adb-2090585310411504.4.azuredatabricks.net"
export DATABRICKS_HOST_PRD="https://adb-2090585310411504.4.azuredatabricks.net"

# Active workspace (switch this when targeting a different environment)
export DATABRICKS_HOST="${DATABRICKS_HOST_DEV}"

# -- Unity Catalog Naming Convention -------------------------------------------
export DATABRICKS_CATALOG_DEV="psp"
export DATABRICKS_CATALOG_PRD="psp_prd"

# Active catalog (must match DATABRICKS_HOST environment)
export DATABRICKS_CATALOG="${DATABRICKS_CATALOG_DEV}"

# -- Schema (Database) Names ---------------------------------------------------
# Schemas within the catalog for each medallion layer
export SCHEMA_BRONZE="bronze"
export SCHEMA_SILVER="silver"
export SCHEMA_GOLD="gold"
export SCHEMA_ANALYTICS="analytics"

# -- SQL Warehouse (for ad-hoc queries and validation) -------------------------
export SQL_WAREHOUSE_ID="<your-sql-warehouse-id>"

# -- Azure Blob Storage (data source) -----------------------------------------
export AZURE_STORAGE_ACCOUNT="owshqblobstg"
export AZURE_STORAGE_CONTAINER="payment-service-provider"

# -- Unity Catalog Volumes (landing zone paths) --------------------------------
export UC_VOLUME_LANDING="/Volumes/${DATABRICKS_CATALOG}/analytics/vol-landing-zone"

# -- DABs Configuration -------------------------------------------------------
# Default target for databricks bundle commands
export DABS_DEFAULT_TARGET="dev"

# Pipeline names follow: psp-{domain}-{target}
export PIPELINE_NAME_PREFIX="psp-payment"

# -- Service Principal (production deployments) --------------------------------
export SERVICE_PRINCIPAL_NAME="psp-service-principal"
export SERVICE_PRINCIPAL_ID="<your-service-principal-id>"

# -- Notification Channels -----------------------------------------------------
export NOTIFICATION_EMAIL_ON_FAILURE="psp-data-alerts@company.com"
export NOTIFICATION_EMAIL_ON_SUCCESS="psp-data-team@company.com"

# -- Data Domains and Entities -------------------------------------------------
# PSP data domains for pipeline orchestration
export DATA_DOMAINS=(transactions merchants settlements chargebacks)
export ENTITY_TYPES=(transactions merchants orders customers payments payouts disputes)

# -- Lakeflow Pipeline Settings ------------------------------------------------
export PIPELINE_EDITION="ADVANCED"
export PIPELINE_CHANNEL="CURRENT"
export PIPELINE_PHOTON="true"
export PIPELINE_SERVERLESS="true"
export PIPELINE_CONTINUOUS="false"
