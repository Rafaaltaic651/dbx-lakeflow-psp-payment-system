#!/usr/bin/env bash
# =============================================================================
# Azure Environment Configuration for PSP Payment System
# =============================================================================
#
# Usage:
#   1. Copy this file: cp azure-env.sh.example azure-env.sh
#   2. Fill in your actual values
#   3. Source it: source configs/azure-env.sh
#
# IMPORTANT: Never commit azure-env.sh to version control.
#            Only this .example file should be tracked.
# =============================================================================

# -- Azure Subscription -------------------------------------------------------
export AZURE_SUBSCRIPTION_ID="<your-azure-subscription-id>"
export AZURE_TENANT_ID="<your-azure-tenant-id>"
export AZURE_RESOURCE_GROUP="psp-payment-system-rg"
export AZURE_REGION="eastus"
export AZURE_ENV="dev"                              # dev | stg | prd

# -- Azure Blob Storage -------------------------------------------------------
# Storage account used by ShadowTraffic to land raw JSONL data
export AZURE_STORAGE_ACCOUNT="owshqblobstg"
export AZURE_STORAGE_CONTAINER="payment-service-provider"

# -- Data Domains --------------------------------------------------------------
# The four core PSP data domains processed by Lakeflow pipelines
export DATA_DOMAINS=(transactions merchants settlements chargebacks)

# All entity types that have source JSONL files in blob storage
export ENTITY_TYPES=(transactions merchants orders customers payments payouts disputes)

# -- Unity Catalog External Locations ------------------------------------------
export UC_EXTERNAL_LOCATION="abfss://${AZURE_STORAGE_CONTAINER}@${AZURE_STORAGE_ACCOUNT}.dfs.core.windows.net/"
export UC_STORAGE_CREDENTIAL="psp-payment-storage-credential"

# -- Tags (applied to all Azure resources) -------------------------------------
export PSP_PROJECT="psp-payment-system"
export PSP_TEAM="data-engineering"
export PSP_COST_CENTER="DE-001"
